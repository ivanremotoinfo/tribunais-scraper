# Porta do servidor (Render define automaticamente via PORT)
PORT=3001

# Origens permitidas pelo CORS (separadas por vírgula)
# Ex: https://seuusuario.github.io,https://suporte.adv.br
CORS_ORIGINS=https://seuusuario.github.io,https://suporte.adv.br

# Habilita Puppeteer para portais com JS pesado (false em free tier Render)
# No Render.com free tier (512MB RAM) mantenha false e use apenas Axios+Cheerio
USE_PUPPETEER=false

# Timeout padrão por consulta (ms) — máx recomendado no Render free: 18000
REQUEST_TIMEOUT=15000

# TTL do cache em memória (segundos) — 3600 = 1 hora
CACHE_TTL=3600

# Chave da API Anthropic — usada para resolver CAPTCHA do TRT5 via Claude Vision
# Sem ela, usa Tesseract OCR (menor precisão para CAPTCHAs distorcidos)
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=
